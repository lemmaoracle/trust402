# ─── Required ──────────────────────────────────────────────────────────
# These values must be set to run the demo agent.

# Demo resource server URL
RESOURCE_URL=http://localhost:3001

# Lemma oracle API key — demo-only key, safe to commit
LEMMA_API_KEY=b6363aa6265322ed0d786a11d5b6d3264947052ca72deba4cbe1685d099af892

# Agent wallet private key (secp256k1 hex, for x402 payments on Base Sepolia)
AGENT_PRIVATE_KEY=

# Holder public key (secp256k1 compressed hex, for document encryption)
HOLDER_PUBLIC_KEY=

# ─── Optional ─────────────────────────────────────────────────────────
# Defaults are shown. Override only if needed.

# Lemma API base URL
# LEMMA_API_BASE=https://workers.lemma.workers.dev

# Maximum spend limit in USD cents (1000 = $10.00)
# MAX_SPEND=1000

# Path to identity artifact
# ARTIFACT_PATH=./artifact.json

# Agent ID (overrides AGENT_ENS_NAME default)
# AGENT_ID=

# Issuer ID (overrides ISSUER_ENS_NAME default)
# ISSUER_ID=

# ENS name for the agent
# AGENT_ENS_NAME=agent.trust402.eth

# ENS name for the issuer
# ISSUER_ENS_NAME=issuer.trust402.eth

# Base Sepolia RPC URL (for blockchain event queries)
# BASE_SEPOLIA_RPC_URL=

# Ethereum mainnet RPC URL for ENS resolution (defaults to public RPC if unset)
# ETHEREUM_RPC_URL=

# KeeperHub webhook URL for spend-limit exceeded alerts
# KEEPERHUB_WEBHOOK_URL=

# Roles Verifier contract address (deployed from @trust402/roles)
# ROLES_VERIFIER_ADDRESS=

# Demo Verifier contract address (deployed from @trust402/demo)
# DEMO_VERIFIER_ADDRESS=

# Pay-to address (for summary display)
# PAY_TO_ADDRESS=

# Pinata (IPFS) — circuit artifact storage
# PINATA_API_KEY=
# PINATA_SECRET_API_KEY=
