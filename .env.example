# Demo Agent Configuration

# Required: Demo resource server URL
RESOURCE_URL=http://localhost:3001

# Required: Lemma API key
LEMMA_API_KEY=

# Optional: Lemma API base URL
LEMMA_API_BASE=https://workers.lemma.workers.dev

# Required: Agent wallet private key (for x402 payments)
AGENT_PRIVATE_KEY=

# Required: Holder public key (secp256k1 compressed hex, for document encryption)
HOLDER_PUBLIC_KEY=

# Optional: Agent ID for auto-generated credential (overrides AGENT_ENS_NAME default)
AGENT_ID=

# Optional: Issuer ID for auto-generated credential (overrides ISSUER_ENS_NAME default)
ISSUER_ID=

# Optional: ENS name for the agent (default: agent.trust402.eth)
AGENT_ENS_NAME=

# Optional: ENS name for the issuer (default: issuer.trust402.eth)
ISSUER_ENS_NAME=

# Optional: Base Sepolia RPC URL for ENS resolution (enables address lookup at startup)
BASE_SEPOLIA_RPC_URL=

# Optional: Maximum spend limit in USD cents (default: 1000 = $10.00)
MAX_SPEND=1000

# Optional: Roles Verifier contract address (deployed from @trust402/roles)
ROLES_VERIFIER_ADDRESS=

# Optional: Demo Verifier contract address (deployed from @trust402/demo)
DEMO_VERIFIER_ADDRESS=

# Optional: Pay-to address (for summary display)
PAY_TO_ADDRESS=

# Pinata (IPFS)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here
