{
  "name": "@trust402/roles",
  "version": "0.0.1",
  "description": "ZK role-enforcement circuits for autonomous agent payments",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "register": "tsx scripts/register-circuit.ts"
  },
  "dependencies": {
    "@lemmaoracle/sdk": "^0.0.22",
    "@lemmaoracle/spec": "^0.0.22",
    "ramda": "^0.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ramda": "^0.30.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
