# Demo Agent Environment Variables
# Copy this file to .env and fill in the values

# Required: Demo resource server URL
RESOURCE_URL=http://localhost:3001

# Required: Lemma API key (get from https://lemma.oracle)
LEMMA_API_KEY=your-lemma-api-key

# Required: Agent wallet private key (for x402 payments)
AGENT_PRIVATE_KEY=0x...

# Required: Holder public key (secp256k1)
HOLDER_PUBLIC_KEY=0x...

# Optional: Path to identity artifact (default: ./artifact.json)
# ARTIFACT_PATH=./artifact.json

# Optional: Maximum spend limit in USD cents (default: 1000 = $10.00)
# MAX_SPEND=1000

# Optional: Lemma API base URL (default: https://workers.lemma.workers.dev)
# LEMMA_API_BASE=https://workers.lemma.workers.dev

# Optional: Agent DID (default: did:trust402:demo-agent)
# AGENT_ID=did:trust402:demo-agent

# Optional: Issuer DID (default: did:trust402:demo-issuer)
# ISSUER_ID=did:trust402:demo-issuer

# Optional: Base Sepolia RPC URL for on-chain verification
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: KeeperHub Webhook URL for spend limit exceeded alerts
# When set, notifications are sent when ZK proof fails due to spend limit exceeding
# KEEPERHUB_WEBHOOK_URL=https://app.keeperhub.com/api/integrations/webhook/your-webhook-id

# Optional: KeeperHub API key for webhook authentication
# KEEPERHUB_API_KEY=your-keeperhub-api-key
